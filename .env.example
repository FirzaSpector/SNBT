# SoalSNBT.id Environment Variables
# Copy file ini ke .env.local dan isi dengan nilai asli

# ============================================
# SUPABASE — Database & Auth
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# DATABASE — Prisma (via Supabase / Neon connection pooler)
# ============================================
# Untuk production: gunakan connection pooler dengan batas limit untuk serverless
# Supabase: tambahkan pooler (port 6543) dan ?pgbouncer=true
# Neon: tambahkan ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DATABASE_URL="postgresql://user:password@ep-shiny-glade-1234.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Untuk migration: gunakan connection langsung tanpa pooler
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ============================================
# MIDTRANS — Payment Gateway Indonesia
# ============================================
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
# Set ke 'true' untuk production (mode sandbox = false)
MIDTRANS_IS_PRODUCTION=false

# ============================================
# ANTHROPIC / CLAUDE — AI Tutor
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SoalSNBT.id

# ============================================
# RATE LIMITING (Upstash Redis — optional)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
